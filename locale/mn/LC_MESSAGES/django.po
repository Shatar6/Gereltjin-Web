msgstr "Бидний туршлага"

msgid "Years Experience"
msgstr "Жилийн туршлага"

msgid "Projects Completed"
msgstr "Дууссан төслүүд"

msgid "Skilled Professionals"
msgstr "Мэргэжлийн боловсон хүчин"

msgid "Quality Guarantee"
msgstr "Чанарын баталгаа"

